  field SFVec3f scale_GP 1 1 1
  field SFRotation rot_GP 0 0 0 0
  field SFVec3f trans_GP 0 0 0
]
{
  Transform {
    translation IS trans_GP
    scale IS scale_GP
    rotation IS rot_GP
    children [
      Gantry_part {
        # center to 0
        trans_G 0 0 -0.0666
      }
      Gantry_part {
        trans_G 0 0.25 -0.0666
      }
      Gantry_part {
        rot_G 0 0 1 1.5708
        trans_G 0.05 0 -0.0666
      }
      Gantry_part {
        rot_G 0 0 1 1.5708
        trans_G 0.3 0 -0.0666
      }
    ]
  }
}

